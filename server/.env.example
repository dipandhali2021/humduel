# HumDuel Server — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env.

# Server
NODE_ENV=development
PORT=3001

# Database — path to SQLite file (relative to server root)
DATABASE_PATH=./data/humduel.db

# Uploads — directory where audio files are stored
UPLOAD_DIR=./uploads

# CORS — allowed frontend origin(s)
CORS_ORIGIN=http://localhost:5173

# Spotify API (Sprint 3)
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
